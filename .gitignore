# 1. Configuration & Secrets
.env
phpunit.xml
.phpunit.result.cache

# 2. Dependencies
/vendor/

# 3. Writable Folder (Tetap pertahankan folder tapi abaikan isinya)
/writable/cache/*
/writable/debugbar/*
/writable/logs/*
/writable/session/*
/writable/uploads/*

# Kecualikan file .gitkeep agar folder kosong tetap terdeteksi oleh Git
!/writable/**/.gitkeep

